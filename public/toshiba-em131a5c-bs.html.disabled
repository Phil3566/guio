<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Artie — Toshiba EM131A5C-BS Microwave Guide</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --teal: #1a6b5a;
      --teal-dark: #134d41;
      --orange: #e8710a;
      --orange-light: #fff3e6;
      --green-light: #e8f5e9;
      --blue-light: #e3f2fd;
      --purple-light: #f3e5f5;
      --bg: #faf6f1;
      --text: #202124;
      --text-light: #5f6368;
      --border: #e0dcd7;
      --radius: 14px;
    }

    html, body {
      height: 100%;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: var(--bg);
      color: var(--text);
      font-size: 17px;
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      display: flex;
      flex-direction: column;
    }

    /* Skip nav */
    .skip-nav {
      position: absolute;
      top: -100%;
      left: 16px;
      background: var(--teal);
      color: white;
      padding: 8px 16px;
      border-radius: 0 0 8px 8px;
      z-index: 2000;
      font-size: 14px;
      font-weight: 600;
      text-decoration: none;
    }
    .skip-nav:focus {
      top: 0;
    }

    /* Focus styles */
    :focus-visible {
      outline: 3px solid var(--teal);
      outline-offset: 2px;
    }
    button:focus-visible {
      outline: 3px solid var(--teal);
      outline-offset: 2px;
    }

    /* Scrollable content */
    .content {
      flex: 1;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
    }

    /* Hero banner */
    .hero {
      margin: 10px 12px 4px;
      border-radius: 14px;
      background: linear-gradient(135deg, #1a6b5a 0%, #0f4a3e 60%, #0a3a30 100%);
      color: white;
      padding: 14px 16px 10px;
      display: flex;
      gap: 10px;
      align-items: flex-start;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -40px;
      right: -40px;
      width: 160px;
      height: 160px;
      background: rgba(255,255,255,0.05);
      border-radius: 50%;
    }
    .hero-logo {
      width: 60px;
      height: 60px;
      object-fit: contain;
      flex-shrink: 0;
    }
    .hero-text h1 {
      font-size: 20px;
      font-weight: 800;
      margin-bottom: 2px;
    }
    .hero-text h1 span {
      color: #f5b731;
    }
    .hero-text p {
      font-size: 14px;
      opacity: 1;
      line-height: 1.5;
    }
    .hero-product {
      text-align: center;
      margin: 2px 12px 4px;
    }
    .hero-product-img {
      width: 220px;
      height: auto;
      border-radius: 8px;
      cursor: pointer;
      transition: transform 0.2s;
    }
    .hero-product-img:active { transform: scale(0.97); }

    /* Fullscreen image overlay */
    .img-fullscreen {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 2000;
      background: rgba(0,0,0,0.85);
      justify-content: center;
      align-items: center;
      cursor: pointer;
    }
    .img-fullscreen.active { display: flex; }
    .img-fullscreen img {
      max-width: 92vw;
      max-height: 88vh;
      border-radius: 12px;
      object-fit: contain;
    }
    .img-fullscreen-close {
      position: absolute;
      top: 16px;
      right: 16px;
      background: rgba(255,255,255,0.9);
      color: #202124;
      border: none;
      font-size: 15px;
      font-weight: 700;
      padding: 12px 20px;
      min-height: 44px;
      border-radius: 22px;
      cursor: pointer;
    }

    .ai-gradient {
      background: linear-gradient(135deg, #ffd000, #ff85e0, #90e0ff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      font-weight: 900;
      font-size: 110%;
    }

    /* Quick reference button */
    .ref-btn {
      display: flex;
      align-items: center;
      gap: 10px;
      margin: 6px 12px 0;
      padding: 12px 14px;
      min-height: 44px;
      background: linear-gradient(135deg, #1a6b5a, #0f4a3e);
      color: white;
      border-radius: 10px;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      transition: transform 0.1s;
      border: none;
      width: calc(100% - 24px);
      text-align: left;
      font-family: inherit;
      font-size: inherit;
    }
    .ref-btn:active { transform: scale(0.97); }
    .ref-btn:focus-visible { outline-color: #f5b731; }
    .ref-btn-icon { font-size: 22px; flex-shrink: 0; }
    .ref-btn-text { flex: 1; }
    .ref-btn-title { font-size: 15px; font-weight: 700; }
    .ref-btn-desc { font-size: 12px; }
    .ref-btn-chevron { font-size: 20px; }

    /* Reference overlay */
    .ref-overlay {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 1000;
      background: var(--bg);
      flex-direction: column;
    }
    .ref-overlay.active { display: flex; }
    .ref-overlay-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px;
      background: white;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    .ref-overlay-title { font-size: 18px; font-weight: 700; color: inherit; }
    .ref-overlay-close {
      background: var(--teal);
      color: white;
      border: none;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      padding: 12px 20px;
      min-height: 44px;
      line-height: 1;
      border-radius: 22px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .ref-overlay-close:active { opacity: 0.8; }
    .ref-overlay-body {
      flex: 1;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      padding: 12px 16px 40px;
    }
    .ref-section-header {
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: white;
      padding: 8px 12px;
      border-radius: 6px;
      margin-top: 16px;
      margin-bottom: 8px;
    }
    .ref-section-header:first-child { margin-top: 0; }
    .ref-section-header.blue { background: #1a73e8; }
    .ref-section-header.green { background: #1e7d45; }
    .ref-section-header.brown { background: #8d6e1f; }
    .ref-section-header.red { background: #b71c1c; }
    .ref-section-header.black { background: #222; }
    .ref-row {
      padding: 7px 0;
      border-bottom: 1px solid #ebe7e2;
    }
    .ref-row:last-child { border-bottom: none; }
    .ref-label {
      font-size: 14px;
    }
    .ref-label strong { font-weight: 700; }
    .ref-desc {
      font-size: 15px;
      color: var(--text-light);
      display: inline;
    }
    .btn-tag {
      display: inline-block;
      background: #2d2d2d;
      color: #fff;
      font-size: 12px;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 4px;
      margin-right: 4px;
      vertical-align: middle;
      letter-spacing: 0.3px;
    }
    .tag-yes {
      display: inline-block;
      background: #1e7d45;
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      padding: 1px 6px;
      border-radius: 3px;
      margin-right: 4px;
    }
    .tag-no {
      display: inline-block;
      background: #b71c1c;
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      padding: 1px 6px;
      border-radius: 3px;
      margin-right: 4px;
    }
    .tag-caution {
      display: inline-block;
      background: #e6a000;
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      padding: 1px 6px;
      border-radius: 3px;
      margin-right: 4px;
    }
    /* Snap & Ask mode cards */
    .snap-mode-card {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 20px;
      background: white;
      border: 2px solid var(--border);
      border-radius: var(--radius);
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      transition: transform 0.1s, border-color 0.2s;
      text-align: left;
      font-family: inherit;
      width: 100%;
    }
    .snap-mode-card:active { transform: scale(0.97); }
    .snap-mode-card:hover,
    .snap-mode-card:focus-visible { border-color: var(--teal); }
    .snap-mode-icon { font-size: 36px; flex-shrink: 0; }
    .snap-mode-title { font-size: 17px; font-weight: 700; color: var(--text); margin-bottom: 2px; }
    .snap-mode-desc { font-size: 13px; color: var(--text-light); }

    /* Photo thumbnail in chat bubble */
    .chat-bubble-photo {
      width: 100%;
      max-width: 200px;
      border-radius: 12px;
      margin-bottom: 6px;
      display: block;
    }

    .ref-codes {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      padding: 8px 0 4px;
    }
    .ref-code {
      background: white;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 4px 10px;
      font-size: 13px;
      white-space: nowrap;
    }
    .ref-code strong {
      color: var(--teal);
    }

    /* Chat view (hidden by default, shown when user asks) */
    .chat-view {
      display: none;
      flex-direction: column;
      flex: 1;
      overflow: hidden;
    }
    .chat-view.active {
      display: flex;
    }
    .content.hidden { display: none; }

    .chat-back {
      padding: 12px 16px;
      background: white;
      border-bottom: 1px solid var(--border);
      font-size: 15px;
      font-weight: 600;
      color: var(--teal);
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
      flex-shrink: 0;
      border: none;
      border-bottom: 1px solid var(--border);
      width: 100%;
      text-align: left;
      font-family: inherit;
    }
    .chat-messages {
      flex: 1;
      overflow-y: auto;
      padding: 16px;
      -webkit-overflow-scrolling: touch;
    }
    .chat-bubble {
      max-width: 85%;
      padding: 12px 16px;
      border-radius: 18px;
      margin-bottom: 8px;
      font-size: 16px;
      line-height: 1.5;
      word-wrap: break-word;
    }
    .chat-bubble.assistant {
      background: white;
      border: 1px solid var(--border);
      border-bottom-left-radius: 4px;
      margin-right: auto;
    }
    .chat-bubble.user {
      background: var(--teal);
      color: white;
      border-bottom-right-radius: 4px;
      margin-left: auto;
    }
    .chat-bubble.typing {
      background: white;
      border: 1px solid var(--border);
      border-bottom-left-radius: 4px;
      margin-right: auto;
      color: var(--text-light);
    }

    /* Input bar */
    .chat-input-label {
      padding: 10px 16px 0;
      background: white;
      border-top: 1px solid var(--border);
      flex-shrink: 0;
      font-size: 15px;
      font-weight: 700;
      color: var(--teal);
      text-align: center;
    }
    .chat-input-row {
      display: flex;
      gap: 8px;
      padding: 8px 16px;
      background: white;
      flex-shrink: 0;
      padding-bottom: env(safe-area-inset-bottom, 10px);
    }
    .chat-input {
      flex: 1;
      padding: 12px 16px;
      border: 2px solid var(--border);
      border-radius: 24px;
      font-size: 16px;
      outline: none;
      font-family: inherit;
      background: var(--bg);
      transition: border-color 0.2s;
    }
    .chat-input:focus { border-color: var(--teal); outline: none; }
    .chat-input:focus-visible { outline: none; border-color: var(--teal); box-shadow: 0 0 0 3px rgba(26,107,90,0.3); }
    .chat-send {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: var(--orange);
      color: white;
      border: none;
      font-size: 20px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: background 0.2s;
    }
    .chat-send:disabled {
      background: #ccc;
      cursor: not-allowed;
    }
    .chat-send:active:not(:disabled) { background: #d06000; }
    .chat-voice {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: var(--teal);
      color: white;
      border: none;
      font-size: 22px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: background 0.2s;
    }
    .chat-voice:active { background: #0f4a3e; }
    .chat-voice.listening {
      background: #b71c1c;
      animation: pulse-mic 1s infinite;
    }
    @keyframes pulse-mic {
      0%, 100% { box-shadow: 0 0 0 0 rgba(183,28,28,0.4); }
      50% { box-shadow: 0 0 0 10px rgba(183,28,28,0); }
    }

    /* Bottom spacing */
    .bottom-spacer { height: 4px; }
  </style>
</head>
<body>

<a href="#chatInput" class="skip-nav">Skip to chat</a>

<!-- ===== HOME VIEW ===== -->
<div class="content" id="homeView" role="main">

  <!-- Hero -->
  <div class="hero">
    <img src="mainlogo.png" alt="Artie the owl mascot" class="hero-logo">
    <div class="hero-text">
      <h1>Hey! I'm <span>Artie.</span></h1>
      <p>I'm your <span class="ai-gradient">AI</span> microwave assistant. I've read every page of the <strong style="font-size:16px;">Toshiba EM131A5C-BS</strong> manual &mdash; ask me anything.</p>
    </div>
  </div>
  <div class="hero-product">
    <img src="toshiba-em131a5c-bs.jpg" alt="Toshiba EM131A5C-BS microwave — tap to enlarge" class="hero-product-img" onclick="document.getElementById('imgFullscreen').classList.add('active')">
  </div>

  <!-- Fullscreen image overlay -->
  <div class="img-fullscreen" id="imgFullscreen" onclick="this.classList.remove('active')">
    <button class="img-fullscreen-close" aria-label="Close image">&#x2190; Back</button>
    <img src="toshiba-em131a5c-bs-full.jpg" alt="Toshiba EM131A5C-BS microwave full size">
  </div>

  <!-- Button Guide Button -->
  <button class="ref-btn" onclick="openButtonGuide()" aria-haspopup="dialog" style="background:linear-gradient(135deg,#43a047,#2e7d32); color:white;">
    <div class="ref-btn-icon" aria-hidden="true">&#x1F518;</div>
    <div class="ref-btn-text">
      <div class="ref-btn-title">Button Guide</div>
      <div class="ref-btn-desc">What every button on the panel does</div>
    </div>
    <div class="ref-btn-chevron" aria-hidden="true">&#x203A;</div>
  </button>

  <!-- Quick Reference Button -->
  <button class="ref-btn" onclick="openRef()" aria-haspopup="dialog" style="background:linear-gradient(135deg,#1e88e5,#1565c0); color:white;">
    <div class="ref-btn-icon" aria-hidden="true">&#x1F4CB;</div>
    <div class="ref-btn-text">
      <div class="ref-btn-title">Quick Reference</div>
      <div class="ref-btn-desc">How to do common tasks step by step</div>
    </div>
    <div class="ref-btn-chevron" aria-hidden="true">&#x203A;</div>
  </button>

  <!-- Snap & Ask Artie Button -->
  <button class="ref-btn" onclick="openSnapAsk()" style="background:linear-gradient(135deg,#f57c00,#e65100); color:white;">
    <div class="ref-btn-icon" aria-hidden="true">&#x1F4F7;</div>
    <div class="ref-btn-text">
      <div class="ref-btn-title">Snap &amp; Ask Artie</div>
      <div class="ref-btn-desc">Take a photo of a dish or food for advice</div>
    </div>
    <div class="ref-btn-chevron" aria-hidden="true">&#x203A;</div>
  </button>

  <!-- Care & Info Button -->
  <button class="ref-btn" onclick="openCare()" aria-haspopup="dialog" style="background:linear-gradient(135deg,#8e24aa,#6a1b9a); color:white;">
    <div class="ref-btn-icon" aria-hidden="true">&#x1F9F9;</div>
    <div class="ref-btn-text">
      <div class="ref-btn-title">Care &amp; Info</div>
      <div class="ref-btn-desc">Cleaning, specs, parts &amp; troubleshooting</div>
    </div>
    <div class="ref-btn-chevron" aria-hidden="true">&#x203A;</div>
  </button>

  <div class="bottom-spacer"></div>
</div>

<!-- ===== QUICK REFERENCE OVERLAY ===== -->
<div class="ref-overlay" id="refOverlay" role="dialog" aria-label="Quick Reference" aria-modal="true">
  <div class="ref-overlay-header" style="background:linear-gradient(135deg,#1e88e5,#1565c0); color:white;">
    <h2 class="ref-overlay-title">Quick Reference</h2>
    <button class="ref-overlay-close" onclick="closeRef()" aria-label="Close quick reference">&#x2190; Back</button>
  </div>
  <div class="ref-overlay-body">

    <h3 class="ref-section-header blue">Cook &amp; Reheat</h3>
    <div class="ref-row"><div class="ref-label"><strong>Reheat food:</strong> <span class="btn-tag">Sensor Reheat</span> &rarr; <span class="btn-tag">START/+30Sec.</span> <span class="ref-desc">&mdash; auto-detects time. Don't open door until time appears.</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Cook (manual):</strong> <span class="btn-tag">Cook Time</span> &rarr; enter time on <span class="btn-tag">0&ndash;9</span> &rarr; <span class="btn-tag">START/+30Sec.</span> <span class="ref-desc">&mdash; full power by default. Press Cook Time FIRST!</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Lower power:</strong> <span class="btn-tag">Cook Time</span> &rarr; enter time &rarr; <span class="btn-tag">Power Level</span> &rarr; press <span class="btn-tag">0&ndash;9</span> &rarr; <span class="btn-tag">START/+30Sec.</span> <span class="ref-desc">&mdash; PL10=full, PL7=70%, PL5=50%, PL3=30%.</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Add 30 sec:</strong> <span class="btn-tag">START/+30Sec.</span> <span class="ref-desc">&mdash; each press = +30 sec at full power. Works while cooking.</span></div></div>
    <div class="ref-row" style="background:#fff8e1; border-radius:6px; padding:8px; margin-top:4px;">
      <div class="ref-label" style="font-size:13px;"><strong>&#x26A0; One Touch Start:</strong> <span class="ref-desc">Pressing <span class="btn-tag">1</span>&ndash;<span class="btn-tag">6</span> without pressing Cook Time first will instantly start cooking at full power for 1&ndash;6 minutes!</span></div>
    </div>

    <h3 class="ref-section-header green">Sensor &amp; Presets</h3>
    <div class="ref-row"><div class="ref-label"><strong>Sensor cook:</strong> press the food button &rarr; <span class="btn-tag">START/+30Sec.</span> <span class="ref-desc">&mdash; don't open door until time appears.</span></div></div>
    <div class="ref-codes">
      <div class="ref-code"><strong>SC-1</strong> Reheat</div>
      <div class="ref-code"><strong>SC-2</strong> Frozen Pizza</div>
      <div class="ref-code"><strong>SC-3</strong> Frozen Entr&eacute;e</div>
      <div class="ref-code"><strong>SC-4</strong> Potato</div>
      <div class="ref-code"><strong>SC-5</strong> Rice</div>
      <div class="ref-code"><strong>SC-6</strong> Fresh Veggie</div>
      <div class="ref-code"><strong>SC-7</strong> Frozen Veggie</div>
    </div>
    <div class="ref-row"><div class="ref-label"><strong>Custom Cook:</strong> <span class="btn-tag">Custom Cook</span> press until code shows &rarr; enter weight &rarr; <span class="btn-tag">START/+30Sec.</span></div></div>
    <div class="ref-codes">
      <div class="ref-code"><strong>CC-1</strong> Bacon</div>
      <div class="ref-code"><strong>CC-2</strong> Rolls/Muffins</div>
      <div class="ref-code"><strong>CC-3</strong> Beverage</div>
      <div class="ref-code"><strong>CC-4</strong> Chicken</div>
      <div class="ref-code"><strong>CC-5</strong> Oatmeal</div>
    </div>
    <div class="ref-row"><div class="ref-label"><strong>Soften/Melt:</strong> <span class="btn-tag">Soften/Melt</span> press until code shows &rarr; enter weight &rarr; <span class="btn-tag">START/+30Sec.</span></div></div>
    <div class="ref-codes">
      <div class="ref-code"><strong>S-1</strong> Melt Butter</div>
      <div class="ref-code"><strong>S-2</strong> Melt Chocolate</div>
      <div class="ref-code"><strong>S-3</strong> Melt Cheese</div>
      <div class="ref-code"><strong>S-4</strong> Marshmallows</div>
      <div class="ref-code"><strong>S-5</strong> Soften Butter</div>
      <div class="ref-code"><strong>S-6</strong> Ice Cream</div>
      <div class="ref-code"><strong>S-7</strong> Cream Cheese</div>
    </div>
    <div class="ref-row"><div class="ref-label"><strong>Popcorn:</strong> press <span class="btn-tag">Popcorn</span> &mdash; 1x=1.75 oz, 2x=3.0 oz, 3x=3.5 oz &rarr; <span class="btn-tag">START/+30Sec.</span></div></div>

    <h3 class="ref-section-header" style="background:#e65100;">Defrost</h3>
    <div class="ref-row"><div class="ref-label"><strong>Custom Defrost:</strong> <span class="btn-tag">Custom Defrost</span> (dEF1=Meat, dEF2=Poultry, dEF3=Fish) &rarr; enter lbs (0.1&ndash;6.0) &rarr; <span class="btn-tag">START/+30Sec.</span> <span class="ref-desc">&mdash; turn food at beep.</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>1 Lb Defrost:</strong> <span class="btn-tag">1lb Defrost</span> &rarr; <span class="btn-tag">START/+30Sec.</span> <span class="ref-desc">&mdash; quick defrost for exactly 1 pound.</span></div></div>

    <h3 class="ref-section-header brown">Clock &amp; Timer</h3>
    <div class="ref-row"><div class="ref-label"><strong>Set clock:</strong> <span class="btn-tag">Clock</span> &rarr; enter time &rarr; <span class="btn-tag">Clock</span> again <span class="ref-desc">&mdash; 12-hour format (1:00&ndash;12:59).</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Timer:</strong> <span class="btn-tag">Kitchen Timer</span> &rarr; enter time &rarr; <span class="btn-tag">START/+30Sec.</span> <span class="ref-desc">&mdash; countdown, no heat.</span></div></div>

    <h3 class="ref-section-header red">Controls</h3>
    <div class="ref-row"><div class="ref-label"><strong>Pause:</strong> <span class="btn-tag">STOP/Cancel</span> once <span class="ref-desc">&mdash; press <span class="btn-tag">START/+30Sec.</span> to resume.</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Cancel all:</strong> <span class="btn-tag">STOP/Cancel</span> twice <span class="ref-desc">&mdash; clears everything.</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Child lock:</strong> hold <span class="btn-tag">STOP/Cancel</span> 3 sec to lock &middot; hold 3 sec again to unlock</div></div>
    <div class="ref-row"><div class="ref-label"><strong>Mute sounds:</strong> long press <span class="btn-tag">8</span> for 3 sec <span class="ref-desc">&mdash; long beep confirms. Repeat to unmute.</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Energy saver:</strong> quick press <span class="btn-tag">STOP/Cancel</span> (under 3 sec) in standby <span class="ref-desc">&mdash; display turns off.</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Save recipe:</strong> <span class="btn-tag">Favorite</span> &rarr; select 1/2/3 &rarr; program cook &rarr; <span class="btn-tag">Favorite</span> to save</div></div>

  </div>
</div>

<!-- ===== BUTTON GUIDE OVERLAY ===== -->
<div class="ref-overlay" id="buttonGuideOverlay" role="dialog" aria-label="Button Guide" aria-modal="true">
  <div class="ref-overlay-header" style="background:linear-gradient(135deg,#43a047,#2e7d32); color:white;">
    <h2 class="ref-overlay-title">Button Guide</h2>
    <button class="ref-overlay-close" onclick="closeButtonGuide()" aria-label="Close button guide">&#x2190; Back</button>
  </div>
  <div class="ref-overlay-body">
    <h3 class="ref-section-header blue">Sensor &amp; Preset Buttons</h3>
    <div class="ref-row"><div class="ref-label"><span class="btn-tag">Sensor Reheat</span> <span class="ref-desc">&mdash; reheats food automatically using steam sensor. Press once, then START. Not for bread, beverages, or frozen food.</span></div></div>
    <div class="ref-row"><div class="ref-label"><span class="btn-tag">Frozen Pizza</span> <span class="ref-desc">&mdash; cooks frozen pizza (6&ndash;12 oz). Press once, then START. Don't open door until time appears.</span></div></div>
    <div class="ref-row"><div class="ref-label"><span class="btn-tag">Frozen Entr&eacute;e</span> <span class="ref-desc">&mdash; cooks frozen meals (8&ndash;32 oz). Press once, then START.</span></div></div>
    <div class="ref-row"><div class="ref-label"><span class="btn-tag">Potato</span> <span class="ref-desc">&mdash; cooks 1&ndash;4 potatoes (10 oz each). Pierce with fork first! Press once, then START.</span></div></div>
    <div class="ref-row"><div class="ref-label"><span class="btn-tag">Rice</span> <span class="ref-desc">&mdash; cooks rice (8&ndash;16 oz). Cover with vented lid. Press once, then START.</span></div></div>
    <div class="ref-row"><div class="ref-label"><span class="btn-tag">Veggie</span> <span class="ref-desc">&mdash; press once for fresh veg (SC-6), twice for frozen veg (SC-7). 4&ndash;16 oz, then START.</span></div></div>
    <div class="ref-row"><div class="ref-label"><span class="btn-tag">Custom Cook</span> <span class="ref-desc">&mdash; 5 preset foods. Press repeatedly to cycle CC-1 Bacon, CC-2 Rolls, CC-3 Beverage, CC-4 Chicken, CC-5 Oatmeal. Enter weight, then START.</span></div></div>
    <div class="ref-row"><div class="ref-label"><span class="btn-tag">Soften/Melt</span> <span class="ref-desc">&mdash; 7 presets for butter, chocolate, cheese, marshmallows, ice cream, cream cheese. Press repeatedly to select S-1 through S-7. Enter weight, then START.</span></div></div>
    <div class="ref-row"><div class="ref-label"><span class="btn-tag">Popcorn</span> <span class="ref-desc">&mdash; pops microwave popcorn. Press 1x for 1.75 oz, 2x for 3.0 oz, 3x for 3.5 oz, then START.</span></div></div>
    <div class="ref-row"><div class="ref-label"><span class="btn-tag">Favorite</span> <span class="ref-desc">&mdash; save/recall up to 3 custom cooking programs. Press to select slot 1, 2, or 3.</span></div></div>

    <h3 class="ref-section-header" style="background:#e65100;">Defrost Buttons</h3>
    <div class="ref-row"><div class="ref-label"><span class="btn-tag">1lb Defrost</span> <span class="ref-desc">&mdash; quick defrost for exactly 1 pound. Press once, then START.</span></div></div>
    <div class="ref-row"><div class="ref-label"><span class="btn-tag">Custom Defrost</span> <span class="ref-desc">&mdash; defrost by food type and weight. Press to cycle dEF1 (Meat), dEF2 (Poultry), dEF3 (Fish). Enter weight (0.1&ndash;6.0 lbs), then START. Flip food at beep.</span></div></div>

    <h3 class="ref-section-header green">Cooking Controls</h3>
    <div class="ref-row"><div class="ref-label"><span class="btn-tag">Cook Time</span> <span class="ref-desc">&mdash; sets manual cooking time. Press FIRST, then enter time on number pad. This prevents accidental One Touch Start!</span></div></div>
    <div class="ref-row"><div class="ref-label"><span class="btn-tag">Power Level</span> <span class="ref-desc">&mdash; sets cooking power (PL1&ndash;PL10). Press after entering cook time, then press 0&ndash;9 to select level.</span></div></div>
    <div class="ref-row"><div class="ref-label"><span class="btn-tag">0&ndash;9</span> <span class="ref-desc">&mdash; number pad. Enter cook time, weight, or food portions. Warning: pressing 1&ndash;6 alone starts One Touch cooking!</span></div></div>
    <div class="ref-row"><div class="ref-label"><span class="btn-tag">8</span> &#x1F50A; <span class="ref-desc">&mdash; number 8 also controls sound. Long press for 3 seconds to mute or unmute all beeps.</span></div></div>

    <h3 class="ref-section-header brown">Clock &amp; Timer</h3>
    <div class="ref-row"><div class="ref-label"><span class="btn-tag">Kitchen Timer</span> <span class="ref-desc">&mdash; countdown timer with no heat. Press, enter time (max 99:59), then START.</span></div></div>
    <div class="ref-row"><div class="ref-label"><span class="btn-tag">Clock</span> <span class="ref-desc">&mdash; sets time of day. Press, enter time, press Clock again. 12-hour format. During cooking, press to see current time.</span></div></div>

    <h3 class="ref-section-header red">Controls</h3>
    <div class="ref-row"><div class="ref-label"><span class="btn-tag">START/+30Sec.</span> <span class="ref-desc">&mdash; starts any cooking program. Also adds 30 seconds during cooking. Press alone for quick 30-second cook.</span></div></div>
    <div class="ref-row"><div class="ref-label"><span class="btn-tag">STOP/Cancel</span> <span class="ref-desc">&mdash; press once to pause, twice to cancel. Hold 3 sec for child lock. Quick press in standby for energy saver.</span></div></div>
    <div class="ref-row"><div class="ref-label"><span class="btn-tag">Power Saving</span> &#x267B; <span class="ref-desc">&mdash; icon below STOP/Cancel. Quick press STOP/Cancel in standby to enter energy saver mode (display off).</span></div></div>
  </div>
</div>

<!-- ===== CARE & INFO OVERLAY ===== -->
<div class="ref-overlay" id="careOverlay" role="dialog" aria-label="Care and Info" aria-modal="true">
  <div class="ref-overlay-header" style="background:linear-gradient(135deg,#8e24aa,#6a1b9a); color:white;">
    <h2 class="ref-overlay-title">Care &amp; Info</h2>
    <button class="ref-overlay-close" onclick="closeCare()" aria-label="Close care and info">&#x2190; Back</button>
  </div>
  <div class="ref-overlay-body">

    <h3 class="ref-section-header blue">Cleaning</h3>
    <div class="ref-row"><div class="ref-label"><strong>Front &amp; front plate:</strong> <span class="ref-desc">hot soapy water on a dish cloth, dry with soft cloth. Remove splashes immediately. No metal or glass scrapers.</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Inside cavity:</strong> <span class="ref-desc">soapy water or vinegar solution, dish cloth, dry completely. No oven spray, abrasives, or scouring pads.</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Door panel:</strong> <span class="ref-desc">glass cleaner with dish cloth. No glass scrapers.</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Cooking compartment recess:</strong> <span class="ref-desc">damp cloth. Don't let water run into turntable drive.</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Turntable &amp; roller ring:</strong> <span class="ref-desc">wash with hot soapy water. Make sure turntable engages properly when replacing.</span></div></div>
    <div class="ref-row" style="background:#f9f4ec; border-radius:6px; padding:8px; margin-top:4px;">
      <div class="ref-label" style="font-size:13px;"><strong>Important:</strong> <span class="ref-desc">clean food spills immediately &mdash; residue on the waveguide cover or cavity can cause sparking and smoke. Never use harsh abrasives or metal scrapers.</span></div>
    </div>

    <h3 class="ref-section-header red">Troubleshooting</h3>
    <div class="ref-row"><div class="ref-label"><strong>Won't turn on:</strong> <span class="ref-desc">check plug, circuit breaker, try another outlet. Close door firmly. Check if "Lock" is on display.</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Arcing or sparking:</strong> <span class="ref-desc">use microwave-safe cookware only. Don't run oven when empty. Clean food residue from cavity.</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Uneven cooking:</strong> <span class="ref-desc">use microwave-safe dishes. Fully defrost frozen food first. Adjust time and power level. Turn or stir food midway.</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Overcooked food:</strong> <span class="ref-desc">reduce cooking time and/or use a lower power level.</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Undercooked food:</strong> <span class="ref-desc">use proper cookware, defrost fully, check vents aren't blocked, increase time or power.</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Improper defrosting:</strong> <span class="ref-desc">use microwave-safe cookware. Adjust time and power. Turn or stir food during defrost.</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Display blank (energy saver):</strong> <span class="ref-desc">press any button or open door to wake up. This is normal &mdash; not a malfunction.</span></div></div>

    <h3 class="ref-section-header green">Specifications</h3>
    <div class="ref-row"><div class="ref-label"><strong>Model:</strong> <span class="ref-desc">Toshiba EM131A5C-BS</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Power:</strong> <span class="ref-desc">1,100W output &middot; 1,550W input &middot; 120V, 60Hz</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Capacity:</strong> <span class="ref-desc">1.2 cu.ft.</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Outside size:</strong> <span class="ref-desc">20.5&quot; x 17.1&quot; x 12.8&quot; (W x D x H)</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Turntable:</strong> <span class="ref-desc">12.4&quot; diameter</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Weight:</strong> <span class="ref-desc">34.6 lbs</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Clearance needed:</strong> <span class="ref-desc">3&quot; sides, 3&quot; top, 1&quot; rear. Min 3 ft installation height.</span></div></div>

    <h3 class="ref-section-header" style="background:#e6a000;">Replacement Parts</h3>
    <div class="ref-row"><div class="ref-label"><strong>Glass tray:</strong> <span class="ref-desc">12.4&quot; turntable glass tray</span></div></div>
    <div class="ref-row"><div class="ref-label"><strong>Turntable ring assembly:</strong> <span class="ref-desc">roller ring with wheels</span></div></div>
    <div class="ref-row" style="background:#f9f4ec; border-radius:6px; padding:8px; margin-top:4px;">
      <div class="ref-label" style="font-size:13px;"><strong>Order parts:</strong> <span class="ref-desc">contact Toshiba customer support or search for your model number (EM131A5C-BS) on Amazon for replacement parts.</span></div>
    </div>

    <h3 class="ref-section-header" style="background:#78909c;">Official Manual</h3>
    <div class="ref-row"><div class="ref-label"><span class="ref-desc">Search for "Toshiba EM131A5C-BS manual" online, or contact Toshiba customer support for a replacement copy.</span></div></div>

    <div style="margin-top:16px; padding:12px; background:#fff8e1; border-left:4px solid #e6a000; border-radius:6px; font-size:13px; color:#5f6368; line-height:1.5;">
      This tool is intended as a helpful guide and may contain errors. Always refer to the official Toshiba owner's manual for complete and accurate information.
    </div>

  </div>
</div>

<!-- ===== SNAP & ASK MODE SELECTOR ===== -->
<div class="ref-overlay" id="snapAskOverlay" role="dialog" aria-label="Snap and Ask Artie" aria-modal="true">
  <div class="ref-overlay-header" style="background:linear-gradient(135deg,#f57c00,#e65100); color:white;">
    <h2 class="ref-overlay-title">Snap &amp; Ask Artie</h2>
    <button class="ref-overlay-close" onclick="closeSnapAsk()" aria-label="Close snap and ask">&#x2190; Back</button>
  </div>
  <div class="ref-overlay-body" style="display:flex; flex-direction:column; gap:16px; padding-top:24px;">
    <p style="text-align:center; color:var(--text-light); font-size:15px;">What do you want to check?</p>

    <button class="snap-mode-card" onclick="startCapture('cookware')">
      <div class="snap-mode-icon" aria-hidden="true">&#x1F372;</div>
      <div>
        <div class="snap-mode-title">Can I use this dish?</div>
        <div class="snap-mode-desc">Take a photo of a bowl, plate, container, or cup</div>
      </div>
    </button>

    <button class="snap-mode-card" onclick="startCapture('food')">
      <div class="snap-mode-icon" aria-hidden="true">&#x1F966;</div>
      <div>
        <div class="snap-mode-title">What should I do with this food?</div>
        <div class="snap-mode-desc">Take a photo of food you want to cook or reheat</div>
      </div>
    </button>

    <p style="text-align:center; color:var(--text-light); font-size:12px; margin-top:8px;">
      Photos are sent to Artie for analysis and are not stored.
    </p>
  </div>
</div>

<!-- Hidden file input for camera -->
<input type="file" id="cameraInput" accept="image/*" capture="environment"
       style="display:none;" onchange="handlePhoto(event)">

<!-- ===== CHAT VIEW ===== -->
<div class="chat-view" id="chatView">
  <button class="chat-back" onclick="goHome()">&#x2039; Back</button>
  <div class="chat-messages" id="chatMessages" aria-live="polite" aria-relevant="additions"></div>
</div>

<!-- Input (always visible) -->
<label class="chat-input-label" for="chatInput">&#x1F4AC; Ask Artie anything about your microwave</label>
<div class="chat-input-row">
  <input type="text" class="chat-input" id="chatInput"
         placeholder="Ask Artie anything..."
         enterkeyhint="send"
         autocomplete="off">
  <button class="chat-voice" id="chatVoice" onclick="toggleVoice()" aria-label="Voice input">&#x1F3A4;</button>
  <button class="chat-send" id="chatSend" onclick="sendMessage()" aria-label="Send message">&#x27A4;</button>
</div>

<script>
  const DEVICE_ID = "toshiba-em131a5c-bs";

  const SYSTEM_PROMPT = `You are Artie, the ClearLabel assistant for the Toshiba EM131A5C-BS microwave oven.

Your job is to help users — especially older adults and people who find electronics confusing — understand how to use their microwave. Always be warm, patient, and encouraging. Never be condescending.

RULES:
- Give short, clear, numbered steps. Maximum 5 steps per answer.
- Use plain English. Say "press" not "actuate". Say "the START/+30Sec. button" not "initiate cooking sequence".
- When describing a button, say where it is on the panel (e.g. "the red STOP/Cancel button at the bottom right").
- If the user seems frustrated or confused, acknowledge it warmly before answering.
- Only answer questions about this microwave. For anything else, say: "I'm only set up to help with this Toshiba microwave — for other questions, a quick web search should help!"
- Never guess. If you don't know, say so and suggest they check the manual.
- Keep answers under 150 words. Be concise.
- Your name is Artie.

PHOTO SAFETY:
- You may receive photos from users. ONLY respond to photos of food, dishes, cookware, containers, or this microwave.
- If a photo does not show food, cookware, or a microwave, respond ONLY with: "I can only help with food and cookware photos for your microwave. Please send a picture of the food you want to cook or the dish you want to check!"
- Do NOT describe, analyze, or comment on inappropriate, explicit, violent, or off-topic images. Do not acknowledge what is in the photo. Just give the redirect message above.
- Never generate content that is harmful, explicit, or unrelated to microwave usage.

DEVICE INFO:
Model: Toshiba EM131A5C-BS, 1100W output, 1.2 cu.ft., 120V/60Hz

PANEL LAYOUT:
[Display Window] — shows time, codes, settings

SENSOR MICROWAVE & PRESETS (top section):
Row 1: [Sensor Reheat] [Frozen Pizza] [Frozen Entrée]
Row 2: [Potato] [Rice] [Veggie]
[Custom Cook]                    [Soften/Melt]
[Popcorn] [Favorite] [Clock]
[1lb Defrost] [Custom Defrost] [Kitchen Timer]

ONE TOUCH START number pad:
[1][2][3]
[4][5][6]
[7][8 🔊On/Off][9]
[Power Level] [0] [Cook Time]

Bottom row: [START/+30Sec.] (left)  [STOP/Cancel] (right)
Power Saving icon below STOP/Cancel

FUNCTION REFERENCE:
- Manual Cook: Press Cook Time → enter time → (optional: Power Level → press 0-9) → START/+30Sec. Full power (PL10) by default. Max 99:59.
- IMPORTANT: You MUST press Cook Time first before entering time! Pressing number 1-6 without Cook Time triggers One Touch Start (instant cooking).
- One Touch Start: Pressing 1-6 alone instantly starts cooking at full power for 1-6 min. Many users do this accidentally.
- Add 30 sec: Press START/+30Sec while cooking. Works during cooking and time defrost. Does NOT work during weight defrost or kitchen timer.
- Power Level: 10 levels (PL10=100% down to PL1=10%). Press after entering cook time, then press number 0-9. During cooking, press Power Level to view current level for 3 sec.
- Sensor Reheat (SC-1): Press Sensor Reheat → START. Don't open door until time appears. Not for bread/dry food/beverages/frozen/raw. Food min 40°F. 8-32 oz.
- Frozen Pizza (SC-2): Press Frozen Pizza → START. 6-12 oz.
- Frozen Entrée (SC-3): Press Frozen Entrée → START. 8-32 oz.
- Potato (SC-4): Press Potato → START. 1-4 potatoes, 10oz each. Puncture with fork, space 1" apart.
- Rice (SC-5): Press Rice → START. 8-16 oz.
- Fresh Veggie (SC-6): Press Veggie once → START. 4-16 oz.
- Frozen Veggie (SC-7): Press Veggie twice → START. 4-16 oz.
- Custom Cook: Press repeatedly for CC-1 to CC-5, enter weight → START. CC-1=Bacon(2-6 slices), CC-2=Frozen Roll/Muffin(1-6 pcs), CC-3=Beverage(1-2 cups), CC-4=Chicken(0.5-2.0 lbs), CC-5=Oatmeal(20/40 oz).
- Soften/Melt: Press repeatedly for S-1 to S-7, enter weight → START. S-1=Melt Butter(1-3 sticks), S-2=Melt Chocolate(4/8 oz), S-3=Melt Cheese(8/16 oz), S-4=Melt Marshmallows(5/10 oz), S-5=Soften Butter(1-3 sticks), S-6=Soften Ice Cream(6/12/16 oz), S-7=Soften Cream Cheese(3/8 oz).
- Popcorn: Press Popcorn — 1x=1.75oz, 2x=3.0oz, 3x=3.5oz → START.
- Custom Defrost: Press for dEF1(Meat)/dEF2(Poultry)/dEF3(Fish) → enter weight (0.1-6.0 lbs) → START. Turn food at beep.
- 1 Lb Defrost: Press 1lb Defrost → START. Pre-set for 1.0 lb.
- Kitchen Timer: Press Kitchen Timer → enter time (max 99:59) → START. No heat. Cannot add time during timer.
- Clock: Press Clock → enter time (1:00-12:59) → Clock. 12-hour format.
- Favorite: Save up to 3 procedures. Press Favorite to select slot, program cook settings, Favorite to save.
- Multi-Stage: Up to 2 stages. Defrost must be first if included. Quick Touch Presets cannot be used.
- Child Lock: Hold STOP/Cancel 3 sec to lock/unlock. "Lock" on display.
- Mute: Long press 8 for 3 sec. All sounds off. Repeat to unmute. Works under lock.
- Energy Saver: Quick press STOP/Cancel (<3 sec) in standby. Display off. Press any button to wake.
- Inquiring: During cooking, press Clock for time, Power Level for power (3 sec display).
- STOP/Cancel: 1x=pause, 2x=cancel all.
- Beeps: 1=confirmed, 1 at halfway defrost=turn food, 5=done("End" shows).

SAFETY:
- No metal, aluminum trays, foil, metal twist-ties, metal-trimmed dishes
- No paper bags, plastic foam (Styrofoam), or wood
- Never heat whole eggs or sealed containers (will explode)
- Pierce potatoes, sausages, plastic pouches before cooking
- Keep 3" clearance on sides and top, 1" in rear`;

  const COOKWARE_PHOTO_PROMPT = `

ADDITIONAL TASK: COOKWARE PHOTO ANALYSIS
The user sent a photo of a dish, bowl, plate, container, or cup. Analyze whether it is safe in this microwave.
IMPORTANT: If the photo does NOT show cookware, a container, or a dish, do NOT analyze it. Respond only with the redirect message from the PHOTO SAFETY rules above.

COOKWARE SAFETY KNOWLEDGE:
SAFE: Microwave-safe labeled dishes, heat-resistant glass (Pyrex), ceramic dinnerware (no metallic trim), glass jars (remove lid, just warm), oven cooking bags (no metal ties), paper plates/cups (short warming), paper towels, parchment paper, wax paper (as cover), microwave-safe plastic (labeled), plastic wrap (microwave-safe, don't touch food), microwave-safe thermometers, browning dish (follow instructions).
UNSAFE: Aluminum trays, metal or metal-trimmed utensils, metal twist-ties, paper bags, plastic foam (Styrofoam), wood.
CAUTION: Food cartons with metal handles (transfer food out), glass jars (may not be heat-resistant), plastic (must be labeled microwave-safe, some soften).

RESPONSE FORMAT:
- Start with a clear verdict: "Safe to use!", "Do NOT use this!", or "Use with caution"
- Explain in 2-3 short sentences
- If you cannot identify the material, say so and suggest the container test: place dish + 1 cup water, run 1 min at full power. Dish stays cool = safe. Dish hot = don't use.
- Under 100 words`;

  const FOOD_PHOTO_PROMPT = `

ADDITIONAL TASK: FOOD PHOTO ANALYSIS
The user sent a photo of food they want to cook or reheat. Give specific instructions for this Toshiba EM131A5C-BS microwave.
IMPORTANT: If the photo does NOT show food, do NOT analyze it. Respond only with the redirect message from the PHOTO SAFETY rules above.

SENSOR PRESETS: SC-1=Sensor Reheat, SC-2=Frozen Pizza(6-12oz), SC-3=Frozen Entrée(8-32oz), SC-4=Potato(1-4, 10oz each), SC-5=Rice(8-16oz), SC-6=Fresh Veggie(4-16oz), SC-7=Frozen Veggie(4-16oz)
CUSTOM COOK: CC-1=Bacon(2-6 slices), CC-2=Frozen Roll/Muffin(1-6 pcs), CC-3=Beverage(1-2 cups), CC-4=Chicken Pieces(0.5-2.0 lbs), CC-5=Oatmeal(20/40 oz)
SOFTEN/MELT: S-1=Melt Butter, S-2=Melt Chocolate, S-3=Melt Cheese, S-4=Melt Marshmallows, S-5=Soften Butter, S-6=Soften Ice Cream, S-7=Soften Cream Cheese

RESPONSE FORMAT:
- Start by naming what you see: "That looks like..."
- If it matches a sensor/custom preset, give those instructions using button names
- If not, give manual cook instructions (Cook Time → time → Power Level → START)
- Max 5 numbered steps
- Include safety warnings when relevant (pierce skins, cover food, stir midway, standing time)
- If you cannot identify the food, ask the user to describe it
- Keep response under 150 words`;

  let pendingPhoto = null;
  let snapMode = null;

  const homeView = document.getElementById("homeView");
  const chatView = document.getElementById("chatView");
  const chatMessages = document.getElementById("chatMessages");
  const chatInput = document.getElementById("chatInput");
  const chatSend = document.getElementById("chatSend");

  const chatVoice = document.getElementById("chatVoice");

  let conversationHistory = [];
  let isWaiting = false;
  let recognition = null;
  let isListening = false;

  // ===== VOICE INPUT (Web Speech API) =====
  function toggleVoice() {
    if (isListening) {
      stopVoice();
      return;
    }

    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SpeechRecognition) {
      alert("Voice input is not supported in this browser. Try Chrome or Safari.");
      return;
    }

    recognition = new SpeechRecognition();
    recognition.lang = "en-US";
    recognition.interimResults = true;
    recognition.continuous = false;

    recognition.onstart = function() {
      isListening = true;
      chatVoice.classList.add("listening");
      chatInput.placeholder = "Listening...";
    };

    recognition.onresult = function(event) {
      let transcript = "";
      for (let i = 0; i < event.results.length; i++) {
        transcript += event.results[i][0].transcript;
      }
      chatInput.value = transcript;
    };

    recognition.onend = function() {
      isListening = false;
      chatVoice.classList.remove("listening");
      chatInput.placeholder = "Ask Artie anything...";
      if (chatInput.value.trim()) {
        sendMessage();
      }
    };

    recognition.onerror = function(event) {
      isListening = false;
      chatVoice.classList.remove("listening");
      chatInput.placeholder = "Ask Artie anything...";
      if (event.error !== "no-speech" && event.error !== "aborted") {
        console.error("Speech recognition error:", event.error);
      }
    };

    recognition.start();
  }

  function stopVoice() {
    if (recognition) {
      recognition.stop();
    }
    isListening = false;
    chatVoice.classList.remove("listening");
    chatInput.placeholder = "Ask Artie anything...";
  }

  chatInput.addEventListener("keydown", (e) => {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  function openRef() {
    const overlay = document.getElementById("refOverlay");
    overlay.classList.add("active");
    overlay.querySelector(".ref-overlay-close").focus();
    document.addEventListener("keydown", trapRefFocus);
  }
  function closeRef() {
    const overlay = document.getElementById("refOverlay");
    overlay.classList.remove("active");
    document.removeEventListener("keydown", trapRefFocus);
    document.querySelector(".ref-btn").focus();
  }
  function trapRefFocus(e) {
    if (e.key === "Escape") { closeRef(); return; }
    if (e.key !== "Tab") return;
    const overlay = document.getElementById("refOverlay");
    const focusable = overlay.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) { e.preventDefault(); last.focus(); }
    } else {
      if (document.activeElement === last) { e.preventDefault(); first.focus(); }
    }
  }


  function openButtonGuide() {
    const overlay = document.getElementById("buttonGuideOverlay");
    overlay.classList.add("active");
    overlay.querySelector(".ref-overlay-close").focus();
    document.addEventListener("keydown", trapButtonGuideFocus);
  }
  function closeButtonGuide() {
    const overlay = document.getElementById("buttonGuideOverlay");
    overlay.classList.remove("active");
    document.removeEventListener("keydown", trapButtonGuideFocus);
  }
  function trapButtonGuideFocus(e) {
    if (e.key === "Escape") { closeButtonGuide(); return; }
    if (e.key !== "Tab") return;
    const overlay = document.getElementById("buttonGuideOverlay");
    const focusable = overlay.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) { e.preventDefault(); last.focus(); }
    } else {
      if (document.activeElement === last) { e.preventDefault(); first.focus(); }
    }
  }

  function openCare() {
    const overlay = document.getElementById("careOverlay");
    overlay.classList.add("active");
    overlay.querySelector(".ref-overlay-close").focus();
    document.addEventListener("keydown", trapCareFocus);
  }
  function closeCare() {
    const overlay = document.getElementById("careOverlay");
    overlay.classList.remove("active");
    document.removeEventListener("keydown", trapCareFocus);
  }
  function trapCareFocus(e) {
    if (e.key === "Escape") { closeCare(); return; }
    if (e.key !== "Tab") return;
    const overlay = document.getElementById("careOverlay");
    const focusable = overlay.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) { e.preventDefault(); last.focus(); }
    } else {
      if (document.activeElement === last) { e.preventDefault(); first.focus(); }
    }
  }

  // ===== SNAP & ASK FUNCTIONS =====
  function openSnapAsk() {
    const overlay = document.getElementById("snapAskOverlay");
    overlay.classList.add("active");
    overlay.querySelector(".ref-overlay-close").focus();
    document.addEventListener("keydown", trapSnapAskFocus);
  }
  function closeSnapAsk() {
    const overlay = document.getElementById("snapAskOverlay");
    overlay.classList.remove("active");
    document.removeEventListener("keydown", trapSnapAskFocus);
  }
  function trapSnapAskFocus(e) {
    if (e.key === "Escape") { closeSnapAsk(); return; }
    if (e.key !== "Tab") return;
    const overlay = document.getElementById("snapAskOverlay");
    const focusable = overlay.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) { e.preventDefault(); last.focus(); }
    } else {
      if (document.activeElement === last) { e.preventDefault(); first.focus(); }
    }
  }

  function startCapture(mode) {
    snapMode = mode;
    closeSnapAsk();
    setTimeout(() => {
      document.getElementById("cameraInput").click();
    }, 100);
  }

  function handlePhoto(event) {
    const file = event.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = function(e) {
      const img = new Image();
      img.onload = function() {
        const MAX_DIM = 1024;
        let width = img.width;
        let height = img.height;
        if (width > MAX_DIM || height > MAX_DIM) {
          if (width > height) {
            height = Math.round(height * (MAX_DIM / width));
            width = MAX_DIM;
          } else {
            width = Math.round(width * (MAX_DIM / height));
            height = MAX_DIM;
          }
        }
        const canvas = document.createElement("canvas");
        canvas.width = width;
        canvas.height = height;
        const ctx = canvas.getContext("2d");
        ctx.drawImage(img, 0, 0, width, height);
        const dataUrl = canvas.toDataURL("image/jpeg", 0.7);
        const base64 = dataUrl.split(",")[1];

        pendingPhoto = { base64, mediaType: "image/jpeg", mode: snapMode, dataUrl };
        sendPhotoMessage();
      };
      img.src = e.target.result;
    };
    reader.readAsDataURL(file);
    event.target.value = "";
  }

  async function sendPhotoMessage() {
    if (!pendingPhoto || isWaiting) return;

    showChat();
    isWaiting = true;
    chatSend.disabled = true;

    const userPrompt = pendingPhoto.mode === "cookware"
      ? "Can I use this dish/container in the microwave? Is it safe?"
      : "I want to microwave this food. How should I cook or reheat it in this Toshiba EM131A5C-BS?";

    // Show user bubble with photo thumbnail
    const userBubble = document.createElement("div");
    userBubble.className = "chat-bubble user";
    const thumbImg = document.createElement("img");
    thumbImg.src = pendingPhoto.dataUrl;
    thumbImg.className = "chat-bubble-photo";
    thumbImg.alt = "Photo you sent";
    userBubble.appendChild(thumbImg);
    const textNode = document.createElement("div");
    textNode.textContent = pendingPhoto.mode === "cookware"
      ? "Can I use this dish in the microwave?"
      : "How should I cook this?";
    userBubble.appendChild(textNode);
    chatMessages.appendChild(userBubble);
    chatMessages.scrollTop = chatMessages.scrollHeight;

    // Build multi-modal message
    const userContent = [
      { type: "image", source: { type: "base64", media_type: pendingPhoto.mediaType, data: pendingPhoto.base64 } },
      { type: "text", text: userPrompt }
    ];
    conversationHistory.push({ role: "user", content: userContent });

    // Typing indicator
    const typing = document.createElement("div");
    typing.className = "chat-bubble typing";
    typing.setAttribute("role", "status");
    typing.textContent = "Artie is looking at your photo...";
    chatMessages.appendChild(typing);
    chatMessages.scrollTop = chatMessages.scrollHeight;

    const photoSystemPrompt = pendingPhoto.mode === "cookware"
      ? SYSTEM_PROMPT + COOKWARE_PHOTO_PROMPT
      : SYSTEM_PROMPT + FOOD_PHOTO_PROMPT;

    const photoMode = pendingPhoto.mode;

    try {
      const response = await fetch("/api/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-haiku-4-5-20251001",
          max_tokens: 1024,
          system: photoSystemPrompt,
          messages: conversationHistory,
          device_id: DEVICE_ID
        })
      });

      typing.remove();

      if (!response.ok) {
        const err = await response.text();
        throw new Error("API error " + response.status);
      }

      const data = await response.json();
      const reply = data.content[0].text;
      conversationHistory.push({ role: "assistant", content: reply });

      // Replace image in history with text summary to save bandwidth
      const lastUserIdx = conversationHistory.length - 2;
      if (conversationHistory[lastUserIdx] && Array.isArray(conversationHistory[lastUserIdx].content)) {
        conversationHistory[lastUserIdx].content = photoMode === "cookware"
          ? "[User sent a photo of cookware/dish for microwave safety check]"
          : "[User sent a photo of food for cooking instructions]";
      }

      const bubble = addBubble("", "assistant");
      formatBubble(bubble, reply);

    } catch (err) {
      typing.remove();
      addBubble("Sorry, I couldn't analyze that photo right now. Please try again.", "assistant");
      console.error("Photo chat error:", err);
    }

    pendingPhoto = null;
    isWaiting = false;
    chatSend.disabled = false;
    chatInput.focus();
  }

  function showChat() {
    homeView.classList.add("hidden");
    chatView.classList.add("active");
  }

  function goHome() {
    chatView.classList.remove("active");
    homeView.classList.remove("hidden");
  }

  function askQuestion(text) {
    chatInput.value = text;
    showChat();
    sendMessage();
  }

  function addBubble(text, role) {
    const bubble = document.createElement("div");
    bubble.className = `chat-bubble ${role}`;
    bubble.textContent = text;
    chatMessages.appendChild(bubble);
    chatMessages.scrollTop = chatMessages.scrollHeight;
    return bubble;
  }

  function formatBubble(bubble, text) {
    let html = text.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
    html = html.replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>");
    html = html.replace(/\n(\d+)\.\s/g, "<br>$1. ");
    html = html.replace(/\n/g, "<br>");
    bubble.innerHTML = html;
  }

  async function sendMessage() {
    const text = chatInput.value.trim();
    if (!text || isWaiting) return;

    showChat();

    addBubble(text, "user");
    chatInput.value = "";
    isWaiting = true;
    chatSend.disabled = true;

    conversationHistory.push({ role: "user", content: text });

    const typing = document.createElement("div");
    typing.className = "chat-bubble typing";
    typing.setAttribute("role", "status");
    typing.textContent = "Thinking...";
    chatMessages.appendChild(typing);
    chatMessages.scrollTop = chatMessages.scrollHeight;

    try {
      const response = await fetch("/api/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-haiku-4-5-20251001",
          max_tokens: 512,
          system: SYSTEM_PROMPT,
          messages: conversationHistory,
          device_id: DEVICE_ID
        })
      });

      typing.remove();

      if (!response.ok) {
        const err = await response.text();
        throw new Error(`API error ${response.status}: ${err}`);
      }

      const data = await response.json();
      const reply = data.content[0].text;
      conversationHistory.push({ role: "assistant", content: reply });
      const bubble = addBubble("", "assistant");
      formatBubble(bubble, reply);

    } catch (err) {
      typing.remove();
      addBubble("Sorry, I couldn't connect right now. Please try again in a moment.", "assistant");
      console.error("Chat error:", err);
    }

    isWaiting = false;
    chatSend.disabled = false;
    chatInput.focus();
  }
</script>

</body>
</html>
